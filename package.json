{
  "name": "comet-like-ai-browser",
  "version": "0.1.0",
  "description": "Minimal AI agentic browser (Electron) with ad blocking, AI sidebar, Google search, and import wizard",
  "license": "MIT",
  "main": "electron/main.js",
  "author": "",
  "scripts": {
    "start": "electron .",
    "dev": "electronmon --trace-warnings .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "jest"
  },
  "dependencies": {
  "@cliqz/adblocker-electron": "^1.34.0",
    "sql.js": "^1.11.0",
    "cross-fetch": "^4.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "electronmon": "^2.0.2",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "com.example.aiagentbrowser",
  "productName": "XerironX Browser",
    "files": [
      "electron/**",
      "src/**",
      "logo.png",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg"],
      "icon": "logo.png"
    },
    "dmg": {
      "icon": "logo.png"
    }
  }
}
